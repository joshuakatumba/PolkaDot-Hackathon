# Backend Environment Variables Template
# Copy this file to .env and fill in the values

# Port for the API server (default 3001)
PORT=3001

# The address of the deployed AutoTreasury contract
VAULT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# The private key for the yield monitor (MUST have funds for rebalance transactions)
PRIVATE_KEY=your_private_key_here

# RPC URL for the network (default is Westend Asset Hub)
RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
